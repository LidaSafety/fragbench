PYTHON = python
MAX_CONCURRENCY = 32

SEED_FILES = $(wildcard seeds/*.json)
MANUAL_RESULT_FILES := $(patsubst seeds/%.json,results/%_manual.json,$(SEED_FILES))
LLM_RESULT_FILES := $(patsubst seeds/%.json,results/%_llm.json,$(SEED_FILES))

.PHONY: all slow
all: $(MANUAL_RESULT_FILES)

slow: all $(LLM_RESULT_FILES)

results/%_manual.json: seeds/%.json
	$(PYTHON) run.py --generate --seed-file $< --seed 0 --output-json $@
results/%_llm.json: seeds/%.json
	$(PYTHON) run.py --generate --seed-file $< --output-json $@ --no-style-templates --max-concurrency $(MAX_CONCURRENCY)
