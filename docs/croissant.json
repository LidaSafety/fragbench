  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.1",
  "name": "FragBench",
  "alternateName": ["anon-fragbench-neurips/fragbench", "FragBench"],
  "description": "FragBench is a benchmark for studying cross-session fragmentation attacks against LLM inference APIs. It covers 24 campaigns drawn from publicly reported cyber incidents, evaluated in a sandboxed MCP environment against qwen/qwen3.5-122b-a10b. The dataset combines a kill-chain seed library, a DAG fragment decomposer, an RL-based adversarial rewriter, a sandboxed execution validator, and a graph-based cross-session detector.",
  "url": "https://huggingface.co/datasets/anon-fragbench-neurips/fragbench",
  "license": "https://choosealicense.com/licenses/cc-by-4.0/",
  "version": "1.0.0",
  "keywords": [
    "text-classification", "text-generation", "English", "cc-by-4.0",
    "safety", "red-teaming", "jailbreak", "llm-agent", "mcp", "benchmark"
  ],
  "creator": {
    "@type": "Organization",
    "name": "anonfragbenchneurips",
    "url": "https://huggingface.co/anon-fragbench-neurips"
  },
  "dataBiases": "Campaign selection over-represents English-language, DPRK-attributed, and ransomware actors with heavy public threat-intelligence reporting. LLM rewriters (Claude Sonnet 4.6, Claude Opus 4.7, DeepSeek V4 Flash) and judges (gpt-oss:20b, Claude Sonnet 4.6, Claude Opus 4.7, Llama-Guard-4-12B, GPT-4.1-mini) inherit biases from their training data; judge verdicts introduce annotation bias correlated with each model's safety calibration.",
  "personalSensitiveInformation": "None. All prompts are synthetically generated from templated seed files with procedurally substituted placeholders. The dataset contains no real personal information, credentials, or attack infrastructure.",
  "dataCollection": "Validated use cases: (1) benchmarking single-turn safety classifiers against cross-session fragmentation, reported as fragment-level judge pass rate; (2) evaluating graph-based cross-session detectors (GCN, GraphSAGE, GAT, GIN, SVM, MLP, GBT), where aggregate event-level F1 ranges from 0.878 to 0.956. Not validated: training production safety systems, evaluating non-English campaigns, or measuring real-world attack success rates. Limitations: covers 24 campaigns as of early 2026 on a single target model; results are upper-bound estimates under a case-study construction and do not measure real-world attack success probability.",
  "cr:dataSocialImpact": "FragBench enables researchers to evaluate defenses against cross-session fragmentation attacks that evade per-prompt safety classifiers. The primary misuse risk is that adversarially rewritten prompts could assist malicious actors if extracted directly. Mitigations: the most sensitive pipeline outputs are withheld in the gated companion dataset pending coordinated disclosure; the dataset is released under CC BY 4.0 with explicit use-case documentation.",
  "cr:hasSyntheticData": true,
  "isBasedOn": [
    {
      "@type": "sc:Dataset",
      "name": "FragBench Campaign Seed Files",
      "url": "https://anonymous.4open.science/r/fragbench-FE86/seeds/"
    },
    {
      "@type": "sc:Dataset",
      "name": "FragBench RL Outputs (Gated)",
      "url": "https://huggingface.co/datasets/anon-fragbench-neurips/fragbench-restricted"
    }
  ],
  "prov:wasGeneratedBy": [
    {
      "@type": "prov:Activity",
      "@id": "activity-seed-authoring",
      "name": "Campaign Seed Authoring",
      "description": "Kill-chain seed files authored by domain experts from 24 publicly reported cyber-incident campaigns, with inter-author quality review against source threat-intelligence reports."
    },
    {
      "@type": "prov:Activity",
      "@id": "activity-synthetic-generation",
      "name": "Synthetic Fragment Generation",
      "description": "Fragment legitimization and style rephrasing performed by Claude Haiku 4.5. Benign cover sessions synthetically generated by Claude Sonnet 4.5 using few-shot schema examples."
    },
    {
      "@type": "prov:Activity",
      "@id": "activity-adversarial-rewriting",
      "name": "Adversarial Rewriting",
      "description": "RL-style rewriter loop using Claude Sonnet 4.6, Claude Opus 4.7, and DeepSeek V4 Flash as rewriters against LLM safety judges (gpt-oss:20b, Claude Sonnet 4.6, Claude Opus 4.7, Llama-Guard-4-12B, GPT-4.1-mini) to optimize fragments against single-turn-prompt safety classifiers."
    },
    {
      "@type": "prov:Activity",
      "@id": "activity-mcp-validation",
      "name": "MCP Sandbox Execution Validation",
      "description": "Each fragment assembly executed end-to-end in a sandboxed Docker Compose environment with 24 MCP tool servers and qwen/qwen3.5-122b-a10b as the actor model. Assemblies accepted only if the full kill chain executed successfully."
    }
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "repo",
      "name": "repo",
      "description": "The Hugging Face git repository.",
      "contentUrl": "https://huggingface.co/datasets/anon-fragbench-neurips/fragbench/tree/refs%2Fconvert%2Fparquet",
      "encodingFormat": "git+https",
      "sha256": "https://github.com/mlcommons/croissant/issues/80"
    },
    {
      "@type": "cr:FileSet",
      "@id": "parquet-files-for-config-attack_meta",
      "containedIn": {"@id": "repo"},
      "encodingFormat": "application/x-parquet",
      "includes": "attack_meta/*/*.parquet"
    },
    {
      "@type": "cr:FileSet",
      "@id": "parquet-files-for-config-campaign_fragments",
      "containedIn": {"@id": "repo"},
      "encodingFormat": "application/x-parquet",
      "includes": "campaign_fragments/*/*.parquet"
    },
    {
      "@type": "cr:FileSet",
      "@id": "sessions",
      "name": "sessions",
      "description": "Redacted MCP session logs organized by campaign. One JSONL per dispatched fragment session. LLM response content is stripped; tool call structure, verdicts, and timing are retained.",
      "contentUrl": "https://huggingface.co/datasets/anon-fragbench-neurips/fragbench/resolve/main/sessions/",
      "encodingFormat": "application/jsonlines",
      "includes": "**/*.jsonl"
    },
    {
      "@type": "cr:FileSet",
      "@id": "rl-outputs-manual",
      "name": "rl-outputs-manual",
      "description": "Adversarially rewritten fragment prompts from the RL phase (gated). Available at the companion restricted repository.",
      "contentUrl": "https://huggingface.co/datasets/anon-fragbench-neurips/fragbench-restricted/resolve/main/rl-outputs-manual/",
      "encodingFormat": "application/json",
      "includes": "**/*.json"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "dataType": "cr:Split",
      "key": {"@id": "attack_meta_splits/split_name"},
      "@id": "attack_meta_splits",
      "name": "attack_meta_splits",
      "description": "Splits for the attack_meta config.",
      "field": [{"@type": "cr:Field", "@id": "attack_meta_splits/split_name", "dataType": "sc:Text"}],
      "data": [{"attack_meta_splits/split_name": "train"}]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "attack_meta",
      "description": "MCP sandbox run metadata. One record per (campaign, style, seed) execution triple.",
      "field": [
        {"@type": "cr:Field", "@id": "attack_meta/split", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"fileProperty": "fullpath"}, "transform": {"regex": "attack_meta/(?:partial-)?(train)/.+parquet$"}}, "references": {"field": {"@id": "attack_meta_splits/split_name"}}},
        {"@type": "cr:Field", "@id": "attack_meta/run_id", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "run_id"}}},
        {"@type": "cr:Field", "@id": "attack_meta/campaign", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "campaign"}}},
        {"@type": "cr:Field", "@id": "attack_meta/style", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "style"}}},
        {"@type": "cr:Field", "@id": "attack_meta/fragments_path", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "fragments_path"}}},
        {"@type": "cr:Field", "@id": "attack_meta/seeds", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "seeds"}}},
        {"@type": "cr:Field", "@id": "attack_meta/started_at", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "started_at"}}},
        {"@type": "cr:Field", "@id": "attack_meta/ended_at", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "ended_at"}}},
        {"@type": "cr:Field", "@id": "attack_meta/target_model", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "target_model"}}},
        {"@type": "cr:Field", "@id": "attack_meta/target_backend", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "target_backend"}}},
        {"@type": "cr:Field", "@id": "attack_meta/llm_product", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "llm_product"}}},
        {"@type": "cr:Field", "@id": "attack_meta/judge_model", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "judge_model"}}},
        {"@type": "cr:Field", "@id": "attack_meta/status", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "status"}}},
        {"@type": "cr:Field", "@id": "attack_meta/num_passed", "dataType": "cr:Int64", "source": {"fileSet": {"@id": "parquet-files-for-config-attack_meta"}, "extract": {"column": "num_passed"}}}
      ]
    },
    {
      "@type": "cr:RecordSet",
      "dataType": "cr:Split",
      "key": {"@id": "campaign_fragments_splits/split_name"},
      "@id": "campaign_fragments_splits",
      "name": "campaign_fragments_splits",
      "description": "Splits for the campaign_fragments config.",
      "field": [{"@type": "cr:Field", "@id": "campaign_fragments_splits/split_name", "dataType": "sc:Text"}],
      "data": [{"campaign_fragments_splits/split_name": "train"}]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "campaign_fragments",
      "description": "One record per fragment per variation. Contains the attack prompt, MITRE tactic, DAG edges, and per-style rewritten variants.",
      "field": [
        {"@type": "cr:Field", "@id": "campaign_fragments/split", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"fileProperty": "fullpath"}, "transform": {"regex": "campaign_fragments/(?:partial-)?(train)/.+parquet$"}}, "references": {"field": {"@id": "campaign_fragments_splits/split_name"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/campaign", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "campaign"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/campaign_id", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "campaign_id"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/seed", "dataType": "cr:Int64", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "seed"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/total_fragments", "dataType": "cr:Int64", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "total_fragments"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/fragment_index", "dataType": "cr:Int64", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "fragment_index"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/role", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "role"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/parent_tactic", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "parent_tactic"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/parent_prompt", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "parent_prompt"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/produces", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "produces"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/consumes", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "consumes"}}},
        {"@type": "cr:Field", "@id": "campaign_fragments/variations", "dataType": "sc:Text", "source": {"fileSet": {"@id": "parquet-files-for-config-campaign_fragments"}, "extract": {"column": "variations"}}}
      ]
    }
  ]
}
